view hashtag_usage  {
  hashtag_id  String @unique @db.Uuid
  usage_count BigInt
}

view post_like_counts {
  post_id     String @unique @db.Uuid
  likes_count BigInt
}

view comment_like_counts {
  comment_id  String @unique @db.Uuid
  likes_count BigInt
}


// No DM reactions
// No post share/repost tracking
// No user activity/online status

enum ContentType {
  post
  story
  scan
}

enum Visibility {
  public
  followers
  private
}

enum DeviceType {
  ios
  android
  web
}

enum NotificationType {
  mention
  like
  comment
  reply
  system
  message
}

enum ReportStatus {
  pending
  reviewed
  resolved
  dismissed
}

enum FollowRequestStatus {
  pending
  accepted
  rejected
}

enum MediaType {
  image
  video
}

enum Role {
  admin
  moderator
  user
}

// @exclude
model admin_audits {
  audit_id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  admin_username   String?
  action           String
  target_table     String?
  target_id        String?
  old_data         Json?
  new_data         Json?
  created_at       DateTime @default(now()) @db.Timestamptz(6)

  admin            users?   @relation(fields: [admin_username], references: [username], onDelete: SetNull)

  @@index([admin_username])
  @@index([created_at])
}