/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model blocks {
  id                      BigInt    @id @default(autoincrement())
  blocker_id              String    @db.Uuid // @system
  blocked_id              String    @db.Uuid
  created_at              DateTime  @default(now()) @db.Timestamptz(6)

  blocker                 users     @relation("blocks_blocker_id", fields: [blocker_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  blocked                 users     @relation("blocks_blocked_id", fields: [blocked_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
 
  @@unique([blocker_id, blocked_id])
  @@index([blocked_id], map: "idx_blocks_blocked_id")
  // CONSTRAINT no_self_block CHECK (blocker_id <> blocked_id)
}

// @reference
model categories {
  category_id   Int      @id @default(autoincrement())
  name          String   @unique @db.VarChar(50)

  posts         posts[]

  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
}

// @reference
model tags {
  tag_id    Int         @id @default(autoincrement())
  name      String      @unique @db.VarChar(50)

  post_tags post_tags[]

  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
}

model chat_participants {
  id        BigInt    @id @default(autoincrement())  
  user_id   String?   @db.Uuid // @system
  chat_id   String    @db.Uuid
  joined_at DateTime  @default(now()) @db.Timestamptz(6)

  user      users?    @relation(fields: [user_id], references: [user_id], onDelete: SetNull, onUpdate: NoAction)
  chat      chats     @relation(fields: [chat_id], references: [chat_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, chat_id], where: raw("user_id is NOT NULL"))
  @@index([user_id])
  @@index([chat_id], map: "idx_chat_participants_chat_id")
}

model chats {
  chat_id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title               String?             @db.VarChar(255)
  is_group_chat       Boolean             @default(false)
  created_at          DateTime            @default(now()) @db.Timestamptz(6)

  chat_participants   chat_participants[] // @nested
  messages            messages[]
  notificationTargets notification_targets[]

  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
}

// @system
model comment_likes {
  id         BigInt    @id @default(autoincrement())
  user_id    String?   @db.Uuid
  comment_id String    @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  user       users?    @relation(fields: [user_id], references: [user_id], onDelete: SetNull, onUpdate: NoAction)
  comment    comments  @relation(fields: [comment_id], references: [comment_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, comment_id], where: raw("user_id IS NOT NULL"))
  @@index([user_id])
  @@index([comment_id])
}

model comments {
  comment_id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content                String
  user_id                String?         @db.Uuid // @system
  post_id                String          @db.Uuid // @includeOnCreate
  comment_parent_id      String?         @db.Uuid // @includeOnCreate
  created_at             DateTime        @default(now()) @db.Timestamptz(6)
  updated_at             DateTime        @updatedAt @db.Timestamptz(6)
  is_deleted             Boolean         @default(false) // @system

  user                   users?          @relation(fields: [user_id], references: [user_id], onDelete: SetNull, onUpdate: NoAction)
  post                   posts           @relation(fields: [post_id], references: [content_id], onDelete: Cascade, onUpdate: NoAction)
  comment                comments?       @relation("commentsTocomments", fields: [comment_parent_id], references: [comment_id], onDelete: Cascade, onUpdate: NoAction)

  replies                comments[]      @relation("commentsTocomments")

  reportTargets          report_targets[]
  notificationTargets    notification_targets[]
  comment_likes          comment_likes[]
  mentionTargets         mention_targets[]
  commentHashtags        comment_hashtags[]

  @@index([comment_parent_id], map: "idx_comments_parent_id")
  @@index([post_id], map: "idx_comments_post_id")
  @@index([user_id], map: "idx_comments_user_id")
}

model device_tokens {
  token_id    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid // @system
  token       String    
  device_type DeviceType 
  app_version String?   @db.VarChar(20)
  last_used   DateTime  @default(now()) @db.Timestamptz(6)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)

  user        users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, token])
  @@index([last_used], map: "idx_device_tokens_last_used")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model follows {
  id                         BigInt    @id @default(autoincrement())
  follower_id                String    @db.Uuid // @system
  following_id               String    @db.Uuid
  created_at                 DateTime  @default(now()) @db.Timestamptz(6)

  follower                   users     @relation("follows_follower_id", fields: [follower_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  following                  users     @relation("follows_following_id", fields: [following_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([follower_id, following_id])
  @@index([following_id], map: "idx_follows_following_id")
  // CONSTRAINT no_self_follow CHECK (follower_id <> following_id)
}

model follow_requests {
  id           BigInt    @id @default(autoincrement())
  requester_id String    @db.Uuid // @system
  target_id    String    @db.Uuid
  status       FollowRequestStatus   @default(pending) // @excludeOnCreate
  created_at   DateTime  @default(now()) @db.Timestamptz(6)

  requester    users     @relation("follow_requests_requester", fields: [requester_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  target       users     @relation("follow_requests_target", fields: [target_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([requester_id, target_id])
  @@index([target_id])
  // CONSTRAINT no_self_request CHECK (requester_id <> target_id)
}

// @system
model hashtags {
  hashtag_id    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String          @unique @db.VarChar(100)
  created_at    DateTime        @default(now()) @db.Timestamptz(6)

  contentHashtags content_hashtags[]
  commentHashtags comment_hashtags[]

  @@index([name(ops: raw("gin_trgm_ops"))], map: "idx_hashtags_name_trgm", type: Gin)
}
// @system
model content_hashtags {
  id         BigInt    @id @default(autoincrement())
  content_id String    @db.Uuid
  hashtag_id String    @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  content    contents @relation(fields: [content_id], references: [content_id], onDelete: Cascade, onUpdate: NoAction)
  hashtag    hashtags @relation(fields: [hashtag_id], references: [hashtag_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([content_id, hashtag_id])
  @@index([hashtag_id])
}
// @system
model comment_hashtags {
  id         BigInt    @id @default(autoincrement())
  comment_id String    @db.Uuid
  hashtag_id String    @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  comment  comments @relation(fields: [comment_id], references: [comment_id], onDelete: Cascade, onUpdate: NoAction)
  hashtag  hashtags @relation(fields: [hashtag_id], references: [hashtag_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([comment_id, hashtag_id])
  @@index([hashtag_id])
}

// @reference
model countries {
  country_id  Int         @id @default(autoincrement())
  name        String      @unique @db.VarChar(255)

  cities      cities[] // @nested
  locations   locations[]

  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
}
// @reference
model cities {
  city_id     Int           @id @default(autoincrement())
  name        String        @db.VarChar(255)
  country_id  Int         

  country     countries     @relation(fields: [country_id], references: [country_id], onDelete: Cascade, onUpdate: Cascade)
  locations   locations[]

  @@unique([name, country_id]) 
  @@index([country_id])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
}

model locations {
  location_id      String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  country_id       Int     
  city_id          Int?    
  lat              Decimal?   @db.Decimal(10, 8)
  lng              Decimal?   @db.Decimal(11, 8)
  place_id         String?    @db.VarChar(255)

  country          countries  @relation(fields: [country_id], references: [country_id], onDelete: Cascade, onUpdate: Cascade) // @nested
  city             cities?    @relation(fields: [city_id], references: [city_id], onDelete: SetNull, onUpdate: Cascade) // @nested

  birth_profiles   profiles[] @relation("profiles_birth_locationTolocations")
  current_profiles profiles[] @relation("profiles_current_locationTolocations")

  posts            posts[]
  scans            scans[]
}

model contents {
  content_id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String       @db.Uuid // @system
  type                ContentType           // @system 
  visibility          Visibility   @default(public)
  content_map         Json
  created_at          DateTime     @default(now()) @db.Timestamptz(6)
  updated_at          DateTime     @updatedAt @db.Timestamptz(6)
  is_deleted          Boolean      @default(false) // @system

  user                users        @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  post                posts? // @nested
  story               stories? // @nested
  scan                scans? // @nested
  contentHashtags     content_hashtags[]
}

// @nestedOnly
model media {
  media_id     String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storage_path String
  type         MediaType        
  
  @@index([storage_path])
}

// @system
model mentions {
  mention_id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mentioned_user_id String           @db.Uuid
  mention_target_id String           @db.Uuid
  created_at        DateTime         @default(now()) @db.Timestamptz(6)

  user              users            @relation(fields: [mentioned_user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  mention_target    mention_targets? @relation(fields: [mention_target_id], references: [target_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([mentioned_user_id])
  @@index([mention_target_id])
}

// @system
model mention_targets {
  target_id   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id     String?   @db.Uuid
  comment_id  String?   @db.Uuid

  post        posts?    @relation(fields: [post_id], references: [content_id], onDelete: Cascade, onUpdate: NoAction)
  comment     comments? @relation(fields: [comment_id], references: [comment_id], onDelete: Cascade, onUpdate: NoAction)
  mentions    mentions[]
  
  // Partial unique indexes: each real entity can be a target at most once
  @@unique([post_id],    where: raw("post_id IS NOT NULL"))
  @@unique([comment_id], where: raw("comment_id IS NOT NULL"))
  // ALTER TABLE mention_targets
  // ADD CONSTRAINT single_target_check CHECK (
  //   (post_id IS NOT NULL)::int +
  //   (comment_id IS NOT NULL)::int = 1
  // );
}

model messages {
  message_id   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chat_id      String    @db.Uuid
  sender_id    String?   @db.Uuid // @system
  text_content String?
  sent_at      DateTime  @default(now()) @db.Timestamptz(6)

  chat         chats     @relation(fields: [chat_id], references: [chat_id], onDelete: Cascade, onUpdate: NoAction)
  user         users?    @relation(fields: [sender_id], references: [user_id], onDelete: SetNull, onUpdate: NoAction)

  @@index([chat_id], map: "idx_messages_chat_id")
  @@index([sent_at], map: "idx_messages_sent_at")
  @@index([sender_id])
}

// @system
model notifications {
  notification_id        String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String                   @db.Uuid 
  actor_id               String?                  @db.Uuid // who triggered the notification
  notification_target_id String?                  @db.Uuid
  type                   NotificationType?    
  message                String?        
  delivered_at           DateTime                 @default(now()) @db.Timestamptz(6)
  read_at                DateTime?                @db.Timestamptz(6)

  user                   users                    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  actor                  users?                   @relation("notification_actor", fields: [actor_id], references: [user_id], onDelete: SetNull, onUpdate: NoAction)  
  notification_target    notification_targets?    @relation(fields: [notification_target_id], references: [target_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
  @@index([notification_target_id])
}

// @system
model notification_targets {
  target_id   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id     String?   @db.Uuid
  comment_id  String?   @db.Uuid
  chat_id     String?   @db.Uuid
  
  post        posts?    @relation(fields: [post_id], references: [content_id], onDelete: Cascade, onUpdate: NoAction)
  comment     comments? @relation(fields: [comment_id], references: [comment_id], onDelete: Cascade, onUpdate: NoAction)
  chat        chats?    @relation(fields: [chat_id], references: [chat_id], onDelete: Cascade, onUpdate: NoAction)

  notifications notifications[]

  @@unique([post_id],    where: raw("post_id IS NOT NULL"))
  @@unique([comment_id], where: raw("comment_id IS NOT NULL"))
  @@unique([chat_id],    where: raw("chat_id IS NOT NULL"))
  // ALTER TABLE notification_targets
  // ADD CONSTRAINT single_target_check CHECK (
  //   (post_id IS NOT NULL)::int +
  //   (comment_id IS NOT NULL)::int +
  //   (chat_id IS NOT NULL)::int = 1
  // );
}

// @system
model post_likes {
  id         BigInt    @id @default(autoincrement())
  user_id    String?   @db.Uuid // @system
  post_id    String    @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  user       users?    @relation(fields: [user_id], references: [user_id], onDelete: SetNull, onUpdate: NoAction)
  post       posts     @relation(fields: [post_id], references: [content_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, post_id], where: raw("user_id IS NOT NULL"))
  @@index([user_id])
  @@index([post_id])
}

// @system
model post_tags {
  id      BigInt  @id @default(autoincrement())
  post_id String  @db.Uuid
  tag_id  Int

  post    posts   @relation(fields: [post_id], references: [content_id], onDelete: Cascade, onUpdate: NoAction)
  tag     tags    @relation(fields: [tag_id], references: [tag_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([post_id, tag_id])
  @@index([tag_id])
}

// @nestedOnly
model posts {
  content_id    String          @id @db.Uuid
  category_id   Int?         
  location_id   String?         @db.Uuid
  text_content  String?         // @system

  content       contents        @relation(fields: [content_id], references: [content_id], onDelete: Cascade)
  category      categories?     @relation(fields: [category_id], references: [category_id], onDelete: SetNull, onUpdate: Cascade)
  location      locations?      @relation(fields: [location_id], references: [location_id], onDelete: SetNull, onUpdate: NoAction) // @nested

  comments      comments[]
  post_likes    post_likes[]
  saved_posts   saved_posts[]
  reportTargets report_targets[]
  notificationTargets notification_targets[]
  mentionTargets mention_targets[]
  postTags post_tags[] 
}

model profiles {
  profile_id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                   String     @unique @db.Uuid // @system
  is_private                Boolean?   @default(false)
  bio                       String?
  avatar                    String?
  birth_location_id         String?    @db.Uuid
  current_location_id       String?    @db.Uuid
  first_name                String     @db.VarChar(50)
  last_name                 String     @db.VarChar(50)
  phone_number              String?    @db.VarChar(20)
  birth_date                DateTime?  @db.Date
  created_at                DateTime   @default(now()) @db.Timestamptz(6)

  user                      users      @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  birth_location_details    locations? @relation("profiles_birth_locationTolocations", fields: [birth_location_id], references: [location_id], onDelete: SetNull, onUpdate: NoAction) // @nested
  current_location_details  locations? @relation("profiles_current_locationTolocations", fields: [current_location_id], references: [location_id], onDelete: SetNull, onUpdate: NoAction) // @nested

  reportTargets report_targets[]
}

// @ExcludeOnUpdate
model reports {
  report_id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporter_id      String?            @db.Uuid // @system
  resolver_id      String?            @db.Uuid // @system
  report_target_id String             @db.Uuid
  reason           String?
  status           ReportStatus       @default(pending)  // @system
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  resolved_at      DateTime?          @db.Timestamptz(6) // @system
  
  user             users?             @relation(fields: [reporter_id], references: [user_id], onDelete: SetNull, onUpdate: NoAction)
  resolver         users?             @relation("report_resolver", fields: [resolver_id], references: [user_id], onDelete: SetNull, onUpdate: NoAction)
  report_target    report_targets     @relation(fields: [report_target_id], references: [target_id], onDelete: Cascade, onUpdate: NoAction) // @nested

  @@unique([reporter_id, report_target_id], where: raw("reporter_id is NOT NULL"))
  @@index([reporter_id])
  @@index([resolver_id])
}

// @nestedOnly @ExcludeOnUpdate
model report_targets {
  target_id   String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id     String?     @db.Uuid
  comment_id  String?     @db.Uuid
  story_id    String?     @db.Uuid
  profile_id  String?     @db.Uuid

  post         posts?     @relation(fields: [post_id], references: [content_id], onDelete: Cascade, onUpdate: NoAction)
  comment      comments?  @relation(fields: [comment_id], references: [comment_id], onDelete: Cascade, onUpdate: NoAction)
  story        stories?   @relation(fields: [story_id], references: [content_id], onDelete: Cascade, onUpdate: NoAction)
  profile      profiles?  @relation(fields: [profile_id], references: [profile_id], onDelete: Cascade, onUpdate: NoAction)
  reports      reports[]

  // Partial unique index ensures at most one FK is non‑null
  @@unique([post_id], where: raw("post_id IS NOT NULL"))
  @@unique([comment_id], where: raw("comment_id IS NOT NULL"))
  @@unique([story_id], where: raw("story_id IS NOT NULL"))
  @@unique([profile_id], where: raw("profile_id IS NOT NULL"))
  // ALTER TABLE report_targets
  // ADD CONSTRAINT single_target_check CHECK (
  //   (post_id IS NOT NULL)::int +
  //   (comment_id IS NOT NULL)::int +
  //   (story_id IS NOT NULL)::int = 1
  // );
}

// @system
model roles {
  role_id   Int     @id @default(autoincrement())
  role_name Role    @unique 

  users     users[]
}

// @system
model saved_posts {
  saved_id String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id  String    @db.Uuid
  post_id  String?   @db.Uuid
  saved_at DateTime  @default(now()) @db.Timestamptz(6)

  user     users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  post     posts?    @relation(fields: [post_id], references: [content_id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([user_id, post_id], map: "idx_unique_user_post", where: raw("(post_id IS NOT NULL)"))
  @@index([post_id], map: "idx_saved_posts_post_id")
  @@index([user_id], map: "idx_saved_posts_user_id")
}

// @nestedOnly
model scans {
  content_id     String    @id @db.Uuid
  location_id    String?   @db.Uuid
  metadata       Json?
  timestamp      DateTime  @default(now()) @db.Timestamptz(6)

  content        contents   @relation(fields: [content_id], references: [content_id], onDelete: Cascade)
  location       locations? @relation(fields: [location_id], references: [location_id], onDelete: SetNull, onUpdate: NoAction) // @nested
}

// @nestedOnly @excludeOnUpdate
model stories {
  content_id    String        @id @db.Uuid
  expires_at    DateTime?     @db.Timestamptz(6)

  content       contents      @relation(fields: [content_id], references: [content_id], onDelete: Cascade)
  story_views   story_views[]
  reportTargets report_targets[]
}

// @system
model story_views {
  id        BigInt    @id @default(autoincrement())
  viewer_id String?   @db.Uuid // @system
  story_id  String    @db.Uuid 
  viewed_at DateTime  @default(now()) @db.Timestamptz(6)

  user      users?    @relation(fields: [viewer_id], references: [user_id], onDelete: SetNull, onUpdate: NoAction)
  story     stories   @relation(fields: [story_id], references: [content_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([viewer_id, story_id], where: raw("viewer_id is NOT NULL"))
  @@index([viewer_id])
  @@index([story_id])
}

model users {
  user_id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id                  Int?                @default(3) // @system
  username                 String              @unique @db.VarChar(50)
  email                    String              @unique @db.VarChar(255)
  password                 String              @db.VarChar(60) // @sensitive
  is_active                Boolean             @default(true)   // @system
  is_banned                Boolean             @default(false)  // @system
  updated_at               DateTime            @updatedAt @db.Timestamptz(6)
  created_at               DateTime            @default(now()) @db.Timestamptz(6)

  role                     roles?              @relation(fields: [role_id], references: [role_id], onDelete: SetNull, onUpdate: Cascade)
  
  blocked_users            blocks[]            @relation("blocks_blocker_id")
  blocked_bys              blocks[]            @relation("blocks_blocked_id")
  following                follows[]           @relation("follows_follower_id")
  followers                follows[]           @relation("follows_following_id")
  follow_Requesters        follow_requests[]   @relation("follow_requests_requester")
  follow_requests_targets  follow_requests[]   @relation("follow_requests_target") 
  notification_actors      notifications[]     @relation("notification_actor")
  report_resolvers         reports[]           @relation("report_resolver")

  chat_participants        chat_participants[]
  comment_likes            comment_likes[]
  comments                 comments[]
  device_tokens            device_tokens[]
  mentions                 mentions[]
  messages                 messages[]
  notifications            notifications[]
  post_likes               post_likes[]
  profile                  profiles? // @nested
  reports                  reports[] 
  saved_posts              saved_posts[]
  story_views              story_views[]
  contents                 contents[]

  @@index([username(ops: raw("gin_trgm_ops"))], map: "idx_users_username_trgm", type: Gin)
  @@index([role_id])
  adminAudits admin_audits[]
}

