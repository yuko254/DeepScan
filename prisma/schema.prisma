datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client"
  output          = "../src/ORM/prisma"
  previewFeatures = ["partialIndexes", "views"]
}

generator openapi {
  // https://github.com/nitzano/prisma-openapi
  provider = "prisma-openapi"
  output   = "./generated/openapi"
  title    = "DeepScan API"
  generateYaml  = true
  generateJson  = true
  generateJsDoc = true
}

generator mock_data {
  // https://github.com/kritikio/prisma-generator-fake-data
    provider = "prisma-generator-fake-data"
    output   = "./generated/mock_data/mock_data.ts"
}

// generator docs {
//   provider = "node node_modules/prisma-docs-generator"
// }

generator erd {
  // https://github.com/keonik/prisma-erd-generator
  provider = "prisma-erd-generator"
  output = "./generated/ERD/ERD.svg"
  ignoreEnums  = true
  ignoreViews  = true
}

generator erd1 {
  provider = "prisma-erd-generator"
  output = "./generated/ERD/ERD_extended.svg"
  includeRelationFromFields = true
  ignoreEnums  = true
  ignoreViews  = true
}

generator erd2 {
  provider = "prisma-erd-generator"
  output = "./generated/ERD/ERD.png"
}

generator erd3 {
  provider = "prisma-erd-generator"
  output = "./generated/ERD/ERD.pdf"
}

generator erd4 {
  provider = "prisma-erd-generator"
  output = "./generated/ERD/ERD.md"
}

generator zod {
  // https://github.com/omar-dulaimi/prisma-zod-generator
  provider = "prisma-zod-generator"
  output = "./generated/zod"
}

